%% 系统架构图 - 展示各组件之间的关系

graph TB
    subgraph User["👤 用户交互层"]
        Query["自然语言查询<br/>例: What turbulence model..."]
    end
    
    subgraph LLM_Layer["🤖 LLM推理层"]
        LLM["大语言模型<br/>GPT-4"]
        Prompt["Prompt模板<br/>+ 知识图谱元数据"]
    end
    
    subgraph Strategy["📋 策略生成层"]
        JSON["搜索策略JSON<br/>• search_criteria<br/>• ranking_criteria<br/>• explanation"]
    end
    
    subgraph KG_Layer["🕸️ 知识图谱层"]
        KG_Data["图谱数据<br/>节点: 10,000+<br/>关系: 50,000+"]
        KG_Index["索引结构<br/>• 节点类型索引<br/>• 属性索引"]
    end
    
    subgraph Search_Engine["⚙️ 搜索引擎"]
        Filter["过滤器<br/>标签+属性+关键词"]
        Scorer["评分器<br/>多维度加权"]
        Ranker["排序器<br/>Top-K选择"]
    end
    
    subgraph Retrieval["📥 内容检索层"]
        Node_Info["节点信息"]
        Relation["关系上下文"]
        File_Content["文件内容"]
    end
    
    subgraph Output["📤 结果输出层"]
        Format["格式化器"]
        Result["结构化结果<br/>Markdown格式"]
    end
    
    Query --> LLM
    Prompt --> LLM
    KG_Data -.元数据.-> Prompt
    
    LLM --> JSON
    
    JSON --> Filter
    KG_Data --> Filter
    KG_Index --> Filter
    
    Filter --> Scorer
    Scorer --> Ranker
    
    Ranker --> Node_Info
    Ranker --> Relation
    Ranker --> File_Content
    
    Node_Info --> Format
    Relation --> Format
    File_Content --> Format
    
    Format --> Result
    
    style User fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style LLM_Layer fill:#fff9c4,stroke:#f57c00,stroke-width:2px
    style Strategy fill:#ffebee,stroke:#c62828,stroke-width:2px
    style KG_Layer fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Search_Engine fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style Retrieval fill:#e0f2f1,stroke:#00796b,stroke-width:2px
    style Output fill:#c8e6c9,stroke:#1b5e20,stroke-width:2px
    
    style LLM fill:#fff3cd,stroke:#856404,stroke-width:3px
    style JSON fill:#f8d7da,stroke:#721c24,stroke-width:2px
    style Result fill:#d4edda,stroke:#155724,stroke-width:3px
