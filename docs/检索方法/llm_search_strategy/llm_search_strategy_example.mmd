%% 搜索策略生成示例 - 展示输入输出
%% 左侧：输入（查询+图谱结构）  右侧：输出（策略JSON）

flowchart TD
    subgraph Input["📥 输入"]
        Q["用户查询:<br/>'What turbulence model is used<br/>in axisymmetricCharge case?'"]
        KG["知识图谱结构:<br/>• Case节点: 150个<br/>• File节点: 1200个<br/>• Variable节点: 8000个<br/>• 关系: CONTAINS, HAS_VARIABLE"]
    end
    
    Input --> LLM{🤖 LLM<br/>GPT-4}
    
    LLM --> Output
    
    subgraph Output["📤 输出策略"]
        S1["🎯 搜索条件<br/>node_labels: [Case, File, Variable]<br/>property_filters:<br/>  - name: *turbulence*<br/>  - path: *axisymmetricCharge*<br/>keywords: [turbulence, model]"]
        S2["📊 排序准则<br/>importance_order:<br/>  1. name<br/>  2. type<br/>  3. path<br/>prefer_types: [File, Variable]"]
        S3["💡 策略说明<br/>Search for turbulence-related<br/>files/variables in the specified case"]
    end
    
    Output --> Execute["⚡ 执行搜索"]
    
    Execute --> Results["✅ 检索结果<br/>1. turbulenceProperties (File)<br/>2. turbulenceModel (Variable)<br/>3. RASModel (Variable)<br/>..."]
    
    style Input fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
