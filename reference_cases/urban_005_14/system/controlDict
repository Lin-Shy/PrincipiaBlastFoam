FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     blastFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.005;  //5ms

deltaT          1e-6;//保证计算所得库郎数不超过0.5即可；

writeControl    adjustableRunTime;//自动调整时间步长

writeInterval   1e-4;//每0.0001s一个输出，即共50个输出

cycleWrite      0;

writeFormat     binary;//减少占用空间

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;//从12修改为6

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.5;//最大库郎数

maxDeltaT       1;//最大时间步长

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

functions
{
    impulse
    {
        type            impulse;
        writeControl    writeTime;
        pRef            101325;//修改的和论文中设置一样
    }
    overpressure
    {
        type            overpressure;
        writeControl    writeTime;
        store           yes;
        pRef            101325;//修改的和论文中设置一样
    }
    maxPImpulse
    {
        type            fieldMinMax;
        writeControl    writeTime;
        fields
        (
            overpressure
            impulse
        );
    }
    
