# LLM API Configuration
LLM_API_KEY=sk-4f9c
LLM_MODEL=qwen-plus
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: use a separate LLM for retrieval tools.
# If omitted, retrieval falls back to the LLM_* settings above.
RETRIEVAL_LLM_API_KEY=
RETRIEVAL_LLM_MODEL=
RETRIEVAL_LLM_API_BASE_URL=

# EMBEDDING API Configuration
EMBEDDING_API_KEY=sk-4f9c
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# GraphRAG Configuration

# OpenFOAM Configuration
BLASTFOAM_TUTORIALS=/media/dev/vdb1/linshihao/cases/blastFoam-cases-dataset/blastFoam_tutorials

# System Configuration
MAX_ITERATIONS=50

# Neo4j settings
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678

# Knowledge Graph Retrieval settings
USE_USER_GUIDE_RETRIEVER=true
USE_TUTORIAL_RETRIEVER=true
USE_KNOWLEDGE_MANAGER=true

# Workflow Execution Control
# Set to false to skip the execution agent and end workflow after case setup
ENABLE_EXECUTION=true
# Set to true to enable incremental updates to the physics report
UPDATE_PHYSICS_REPORT=true
